<% content_for :main_class, "flex-1 pt-0" %>

<main class="bg-white text-slate-900">
  <%= render_public_header %>

  <section id="hero" class="bg-slate-50">
    <div class="mx-auto grid max-w-6xl gap-10 px-6 py-20 md:grid-cols-[1.1fr,0.9fr] md:items-center">
      <div class="space-y-6">
        <span class="inline-flex items-center rounded-full bg-indigo-100 px-4 py-1 text-xs font-semibold uppercase tracking-[0.4em] text-indigo-700">Now Building</span>
        <h1 class="text-4xl font-bold leading-tight md:text-5xl">Building Original Games with Malaysian Creativity</h1>
        <p class="text-base text-slate-600 md:text-lg">Artifisi is an independent gaming studio that designs, develops, and publishes original games entirely in-house — bringing fresh worlds and unforgettable experiences to players everywhere.</p>
        <div class="flex flex-col gap-3 sm:flex-row">
          <a data-role="primary-cta" href="#contact" class="inline-flex items-center justify-center rounded-full bg-indigo-600 px-6 py-3 text-sm font-semibold text-white transition hover:-translate-y-0.5 hover:bg-indigo-700">Get started</a>
          <a data-role="secondary-cta" href="#services" class="inline-flex items-center justify-center rounded-full border border-indigo-200 px-6 py-3 text-sm font-semibold text-indigo-600 transition hover:-translate-y-0.5 hover:bg-indigo-50">Learn more</a>
        </div>
      </div>
      <div class="flex justify-center md:justify-end">
        <%= image_tag "hero.webp", alt: "Artifisi hero collage", class: "w-full max-w-lg rounded-3xl border border-slate-200 shadow-lg shadow-slate-300/40" %>
      </div>
    </div>
  </section>

  <section id="about" class="border-b border-slate-200 bg-white">
    <div class="mx-auto max-w-6xl px-6 py-16">
      <div class="grid gap-8 md:grid-cols-2 md:items-center">
        <div class="space-y-6">
          <h2 class="text-2xl font-semibold tracking-tight text-slate-900">About Artifisi</h2>
          <p class="text-sm text-slate-600">Founded in 2024, Artifisi Sdn Bhd is an independent gaming studio based in Malaysia. We design, develop, and publish our own games in-house, combining artistic vision with technical craftsmanship to create original gaming experiences.</p>
        </div>
        <div class="space-y-4 text-sm text-slate-600">
          <div>
            <h3 class="text-sm font-semibold uppercase tracking-[0.35em] text-indigo-600">Our Mission</h3>
            <p class="mt-2">To craft unforgettable gaming experiences that bring players together and showcase Malaysian creativity on the world stage.</p>
          </div>
          <div>
            <h3 class="text-sm font-semibold uppercase tracking-[0.35em] text-indigo-600">Our Vision</h3>
            <p class="mt-2">To become a world-class game studio recognized for original IP, compelling gameplay, and artistic excellence.</p>
          </div>
          <div>
            <h3 class="text-sm font-semibold uppercase tracking-[0.35em] text-indigo-600">Our Approach</h3>
            <p class="mt-2">We build every aspect of our games in-house — from concept art and design to programming and publishing — ensuring a cohesive creative vision from start to finish.</p>
          </div>
        </div>
      </div>
      <div class="mt-12 overflow-hidden rounded-3xl">
        <%= image_tag "values.webp", alt: "Artifisi values montage", class: "w-full object-cover" %>
      </div>
    </div>
  </section>

  <section class="border-b border-slate-200 bg-white">
    <div class="mx-auto max-w-6xl px-6 py-16">
      <header class="space-y-3 text-center">
        <h2 class="text-2xl font-semibold tracking-tight text-slate-900">Our Core Values</h2>
        <p class="text-sm text-slate-600">At Artifisi, our team is guided by a set of core values that shape every game we build and every interaction with our players and partners.</p>
      </header>
      <div class="mt-12 grid gap-6 md:grid-cols-3">
        <% [
          ["Craftsmanship", "We take pride in every pixel, line of code, and design decision — quality is never compromised."],
          ["Player-First Design", "Every feature and mechanic is designed with the player's enjoyment and experience as the top priority."],
          ["Collaboration", "Great games are built by great teams. We foster a creative, supportive environment where every voice matters."],
          ["Agility", "We iterate fast, playtest often, and adapt quickly to create the best possible gaming experiences."],
          ["Continuous Learning", "We embrace a culture of ongoing growth, constantly sharpening our craft and exploring new tools and techniques."],
          ["Malaysian Roots, Global Reach", "We draw inspiration from our local culture and stories to create games that resonate with players around the world."]
        ].each do |title, description| %>
          <article class="flex h-full flex-col gap-3 rounded-2xl border border-slate-200 bg-white p-6 shadow-sm">
            <h3 class="text-lg font-semibold text-slate-900"><%= title %></h3>
            <p class="text-sm text-slate-600"><%= description %></p>
          </article>
        <% end %>
      </div>
    </div>
  </section>

  <section id="services" class="border-b border-slate-200 bg-white">
    <div class="mx-auto max-w-6xl px-6 py-16">
      <header class="space-y-3 text-center">
        <h2 class="text-2xl font-semibold tracking-tight text-slate-900">Our Services</h2>
        <p class="text-sm text-slate-600">We offer end-to-end game development services, from initial concept to final launch.</p>
      </header>
      <div class="mt-12 grid gap-10 md:grid-cols-2">
        <% [
          ["Game Development", "Full-cycle game production using modern engines and tools, from prototype to shipped title."],
          ["Art & Animation", "Original 2D and 3D art, character design, environment creation, and fluid animation that brings worlds to life."],
          ["Game Design", "Compelling mechanics, balanced systems, and engaging narratives crafted to keep players immersed."],
          ["Quality Assurance", "Rigorous playtesting, bug hunting, and performance optimization to ensure a polished player experience."]
        ].each_with_index do |(service, description), index| %>
          <div class="flex gap-4">
            <span class="mt-1 inline-flex h-10 w-10 flex-shrink-0 items-center justify-center rounded-full bg-indigo-600 text-sm font-semibold text-white"><%= index + 1 %></span>
            <div class="space-y-2">
              <h3 class="text-lg font-semibold text-slate-900"><%= service %></h3>
              <p class="text-sm text-slate-600"><%= description %></p>
            </div>
          </div>
        <% end %>
      </div>
    </div>
  </section>

  <section id="projects" class="border-b border-slate-200 bg-slate-50">
    <div class="mx-auto max-w-6xl px-6 py-16">
      <header class="space-y-3 text-center">
        <h2 class="text-2xl font-semibold tracking-tight text-slate-900">Current Projects</h2>
        <p class="text-sm text-slate-600">Explore the games we are actively building in-house.</p>
      </header>
      <div class="mt-10 grid gap-6 md:grid-cols-2">
        <article class="flex h-full flex-col justify-between overflow-hidden rounded-3xl border border-slate-200 bg-white shadow-md">
          <div class="h-40 bg-cover bg-center" style="background-image: url('https://images.unsplash.com/photo-1518770660439-4636190af475?auto=format&fit=crop&w=900&q=80');"></div>
          <div class="space-y-3 px-6 py-6">
            <h3 class="text-lg font-semibold text-slate-900">Project Aether</h3>
            <p class="text-sm text-slate-600">An atmospheric action-adventure game set in a richly detailed world inspired by Southeast Asian mythology and folklore.</p>
            <a href="#" class="inline-flex text-sm font-semibold text-indigo-600 hover:text-indigo-700">Wishlist soon →</a>
          </div>
        </article>
        <article class="flex h-full flex-col justify-between overflow-hidden rounded-3xl border border-slate-200 bg-white shadow-md">
          <div class="h-40 bg-cover bg-center" style="background-image: url('https://images.unsplash.com/photo-1520607162513-77705c0f0d4a?auto=format&fit=crop&w=900&q=80');"></div>
          <div class="space-y-3 px-6 py-6">
            <h3 class="text-lg font-semibold text-slate-900">Tactica</h3>
            <p class="text-sm text-slate-600">A competitive multiplayer tactics game with deep strategic gameplay, vibrant art style, and ranked seasons.</p>
            <a href="#" class="inline-flex text-sm font-semibold text-indigo-600 hover:text-indigo-700">Join playtest →</a>
          </div>
        </article>
      </div>
    </div>
  </section>

  <section id="blog" class="border-b border-slate-200 bg-white">
    <div class="mx-auto max-w-6xl px-6 py-16">
      <header class="space-y-3 text-center">
        <h2 class="text-2xl font-semibold tracking-tight text-slate-900">From the Blog</h2>
        <p class="text-sm text-slate-600">Insights and updates on game development, design, and studio life from the Artifisi team.</p>
      </header>
      <div class="mt-10 grid gap-6 md:grid-cols-3">
        <% if @featured_posts.any? %>
          <% @featured_posts.each do |post| %>
            <article class="flex h-full flex-col justify-between rounded-2xl border border-slate-200 bg-white p-6 shadow-sm transition hover:-translate-y-0.5 hover:shadow-md">
              <div class="space-y-3">
                <p class="text-xs font-semibold uppercase tracking-[0.3em] text-indigo-600"><%= post.status.titleize %></p>
                <h3 class="text-lg font-semibold text-slate-900"><%= post.title %></h3>
                <p class="text-sm text-slate-600"><%= post_excerpt(post.body, length: 120) %></p>
              </div>
              <%= link_to "Read more →", blog_path(post), class: "mt-4 inline-flex text-sm font-semibold text-indigo-600 hover:text-indigo-700" %>
            </article>
          <% end %>
        <% else %>
          <div class="rounded-2xl border border-slate-200 bg-white p-6 text-center text-sm text-slate-500">
            No posts published yet. Check back soon for news from the team.
          </div>
        <% end %>
      </div>
    </div>
  </section>

  <section id="contact" class="bg-white">
    <div class="mx-auto max-w-6xl px-6 py-16">
      <header class="space-y-3 text-center">
        <h2 class="text-2xl font-semibold tracking-tight text-slate-900">Contact Us</h2>
        <p class="text-sm text-slate-600">Ready to collaborate or curious about our work? Let's build games that matter.</p>
      </header>
      <div class="mt-12 grid gap-8 md:grid-cols-[1fr,1.2fr]">
        <div class="space-y-6 text-sm text-slate-600">
          <div>
            <h3 class="text-sm font-semibold uppercase tracking-[0.35em] text-indigo-600">Get in Touch</h3>
            <p class="mt-3">hello@artifisi.com</p>
            <p>+60 12-345 6789</p>
            <p>Artifisi Sdn Bhd<br>Level 23, Plaza Sentral<br>Kuala Lumpur, Malaysia 50470</p>
          </div>
          <div>
            <h3 class="text-sm font-semibold uppercase tracking-[0.35em] text-indigo-600">Follow Us</h3>
            <a class="mt-3 inline-flex items-center gap-2 text-slate-600 hover:text-indigo-600" href="https://x.com/artifisi">@artifisi on X</a>
          </div>
        </div>
        <div class="rounded-3xl border border-slate-200 bg-slate-50 px-6 py-8">
          <%= turbo_frame_tag "contact_form" do %>
            <% if defined?(@contact_submitted) && @contact_submitted %>
              <%= render "contacts/success" %>
            <% else %>
              <%= render "contacts/form", contact: @contact || Contact.new %>
            <% end %>
          <% end %>
        </div>
      </div>
    </div>
  </section>
</main>
